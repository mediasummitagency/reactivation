# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenPhone (Quo)
OPENPHONE_API_KEY=your-openphone-api-key
OPENPHONE_FROM_NUMBER=+1XXXXXXXXXX

# Twilio (dormant — registered but not active)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# SMS Provider: "openphone" or "twilio"
SMS_PROVIDER=openphone

# Demo mode: "true" = intervals in minutes, "false" = intervals in days
DEMO_MODE=true

# Vercel Cron security (auto-generated by Vercel, add manually for local testing)
CRON_SECRET=your-cron-secret
